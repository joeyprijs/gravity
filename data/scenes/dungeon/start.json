      "actions": [
        {
          "type": "loot",
          "item": "cellar_key",
          "log": "You run your hands over the rough planks, feeling for weakness. Nothing gives — but crouching at the threshold, you spot it: a small iron key lying in the gap beneath the door, slid through from the other side. Whoever locked you in wanted you to let yourself out."
        }
      ]
    },
