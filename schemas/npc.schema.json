{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gravity NPC/Enemy Definition",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Visual display name of the NPC."
    },
    "description": {
      "type": "string",
      "description": "Flavor/lore description (printed on combat/encounter card)."
    },
    "isMerchant": {
      "type": "boolean",
      "description": "Set to true to unlock the reactive shop commerce buying and selling panels."
    },
    "storeExitText": {
      "type": "string",
      "description": "Farewell text spoken by the merchant upon leaving the trade view."
    },
    "carriedItems": {
      "type": "array",
      "description": "Items loaded into the merchant's trade stock pool.",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "description": "Item ID shorthand for unlimited stock."
          },
          {
            "type": "object",
            "properties": {
              "item": {
                "type": "string"
              },
              "amount": {
                "type": "integer",
                "minimum": 1,
                "description": "Stock count. Omit for unlimited inventory."
              }
            },
            "required": [
              "item"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "attributes": {
      "type": "object",
      "description": "Combat characteristics for aggressive NPC entities (enemies).",
      "properties": {
        "healthPoints": {
          "type": "integer",
          "minimum": 1
        },
        "armorClass": {
          "type": "integer",
          "minimum": 1
        },
        "actionPoints": {
          "type": "integer",
          "minimum": 0
        },
        "initiative": {
          "type": "integer"
        },
        "xpReward": {
          "type": "integer",
          "minimum": 0,
          "description": "XP awarded on victory."
        }
      },
      "required": [
        "healthPoints",
        "armorClass",
        "actionPoints"
      ],
      "additionalProperties": false
    },
    "equipment": {
      "type": "object",
      "description": "Pre-equipped items (usually a Weapon in 'Right Hand' slot).",
      "properties": {
        "Head": {
          "type": [
            "string",
            "null"
          ]
        },
        "Amulet": {
          "type": [
            "string",
            "null"
          ]
        },
        "Torso": {
          "type": [
            "string",
            "null"
          ]
        },
        "Left Hand": {
          "type": [
            "string",
            "null"
          ]
        },
        "Right Hand": {
          "type": [
            "string",
            "null"
          ]
        },
        "Legs": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "conversations": {
      "type": "object",
      "description": "Graph tree mapping branching dialogues. Key 'start' is the starting conversation node.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "npcText": {
            "type": "string",
            "description": "What the NPC says upon landing on this node."
          },
          "actions": {
            "type": "array",
            "items": {
              "$ref": "scene.schema.json#/definitions/action"
            },
            "description": "Pipeline actions triggered instantly when reaching this node."
          },
          "responses": {
            "type": "array",
            "description": "Player reply choices.",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                },
                "retryText": {
                  "description": "Replacement response text once the check has been attempted this conversation: a string, or an array walked per failed attempt (clamped to the last entry).",
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "minItems": 1
                    }
                  ]
                },
                "condition": {
                  "$ref": "scene.schema.json#/definitions/condition"
                },
                "skillCheck": {
                  "type": "string",
                  "description": "Dynamic attribute ID (e.g. stealth, persuasion) to roll."
                },
                "dc": {
                  "type": "integer",
                  "minimum": 1
                },
                "actions": {
                  "type": "array",
                  "items": {
                    "$ref": "scene.schema.json#/definitions/action"
                  },
                  "description": "Action pipeline executed on standard selections or successful rolls."
                },
                "onFailure": {
                  "type": "array",
                  "items": {
                    "$ref": "scene.schema.json#/definitions/action"
                  },
                  "description": "Action pipeline executed on failed conversational skill rolls."
                },
                "outcomes": {
                  "$ref": "scene.schema.json#/definitions/outcomes"
                },
                "resolveOnce": {
                  "type": "boolean",
                  "description": "The check rolls exactly once, then this response retires permanently — across conversations and saves."
                },
                "maxAttempts": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Attempt budget per conversation. When it runs out the response retires until the conversation restarts; onExhausted runs once."
                },
                "onExhausted": {
                  "type": "array",
                  "items": {
                    "$ref": "scene.schema.json#/definitions/action"
                  },
                  "description": "Pipeline run once when maxAttempts is exhausted this conversation."
                },
                "timeCost": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Ticks this response advances the world clock. Dialogue is free unless set."
                }
              },
              "required": [
                "text"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "npcText"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "name"
  ],
  "additionalProperties": false
}
