{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gravity NPC/Enemy Definition",
  "type": "OBJECT",
  "properties": {
    "name": {
      "type": "STRING",
      "description": "Visual display name of the NPC."
    },
    "description": {
      "type": "STRING",
      "description": "Flavor/lore description (printed on combat/encounter card)."
    },
    "isMerchant": {
      "type": "BOOLEAN",
      "description": "Set to true to unlock the reactive shop commerce buying and selling panels."
    },
    "storeExitText": {
      "type": "STRING",
      "description": "Farewell text spoken by the merchant upon leaving the trade view."
    },
    "carriedItems": {
      "type": "ARRAY",
      "description": "Items loaded into the merchant's trade stock pool.",
      "items": {
        "type": ["STRING", "OBJECT"],
        "properties": {
          "item": { "type": "STRING" },
          "amount": { "type": "INTEGER", "minimum": 1, "description": "Stock count. Omit for unlimited inventory." }
        },
        "required": ["item"],
        "additionalProperties": false
      }
    },
    "attributes": {
      "type": "OBJECT",
      "description": "Combat characteristics for aggressive NPC entities (enemies).",
      "properties": {
        "healthPoints": { "type": "INTEGER", "minimum": 1 },
        "armorClass": { "type": "INTEGER", "minimum": 1 },
        "actionPoints": { "type": "INTEGER", "minimum": 0 },
        "initiative": { "type": "INTEGER" },
        "xpReward": { "type": "INTEGER", "minimum": 0, "description": "XP awarded on victory." }
      },
      "required": ["healthPoints", "armorClass", "actionPoints"],
      "additionalProperties": false
    },
    "equipment": {
      "type": "OBJECT",
      "description": "Pre-equipped items (usually a Weapon in 'Right Hand' slot).",
      "properties": {
        "Head": { "type": ["STRING", "NULL"] },
        "Amulet": { "type": ["STRING", "NULL"] },
        "Torso": { "type": ["STRING", "NULL"] },
        "Left Hand": { "type": ["STRING", "NULL"] },
        "Right Hand": { "type": ["STRING", "NULL"] },
        "Legs": { "type": ["STRING", "NULL"] }
      },
      "additionalProperties": false
    },
    "conversations": {
      "type": "OBJECT",
      "description": "Graph tree mapping branching dialogues. Key 'start' is the starting conversation node.",
      "additionalProperties": {
        "type": "OBJECT",
        "properties": {
          "npcText": { "type": "STRING", "description": "What the NPC says upon landing on this node." },
          "actions": {
            "type": "ARRAY",
            "items": { "$ref": "scene.schema.json#/definitions/action" },
            "description": "Pipeline actions triggered instantly when reaching this node."
          },
          "responses": {
            "type": "ARRAY",
            "description": "Player reply choices.",
            "items": {
              "type": "OBJECT",
              "properties": {
                "text": { "type": "STRING" },
                "condition": { "$ref": "scene.schema.json#/definitions/condition" },
                "skillCheck": { "type": "STRING", "description": "Dynamic attribute ID (e.g. stealth, persuasion) to roll." },
                "dc": { "type": "INTEGER", "minimum": 1 },
                "increment": { "type": "INTEGER", "description": "Conversational DC escalation point added per failure." },
                "actions": {
                  "type": "ARRAY",
                  "items": { "$ref": "scene.schema.json#/definitions/action" },
                  "description": "Action pipeline executed on standard selections or successful rolls."
                },
                "onFailure": {
                  "type": "ARRAY",
                  "items": { "$ref": "scene.schema.json#/definitions/action" },
                  "description": "Action pipeline executed on failed conversational skill rolls."
                }
              },
              "required": ["text"],
              "additionalProperties": false
            }
          }
        },
        "required": ["npcText"],
        "additionalProperties": false
      }
    }
  },
  "required": ["name"],
  "additionalProperties": false
}
