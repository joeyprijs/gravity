{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gravity Scene Definition",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Visual header name of the scene. Takes precedence over 'name'."
    },
    "name": {
      "type": "string",
      "description": "Display name of the scene (used for map tags and fallback headers)."
    },
    "region": {
      "type": "string",
      "description": "Region key from data/index.json indicating map grouping."
    },
    "xpReward": {
      "type": "integer",
      "minimum": 1,
      "description": "One-time XP bonus awarded to the player upon their first entry."
    },
    "descriptionHook": {
      "type": "string",
      "description": "Optional runtime callback hook (e.g., 'museumChestContents') to append dynamic text."
    },
    "mapDefinitions": {
      "type": "object",
      "properties": {
        "top": {
          "type": "integer"
        },
        "left": {
          "type": "integer"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "background": {
          "type": "string",
          "description": "CSS color expression used to draw room nodes on the map canvas."
        }
      },
      "required": [
        "top",
        "left",
        "width",
        "height"
      ],
      "additionalProperties": false
    },
    "questTrigger": {
      "type": "object",
      "properties": {
        "mission": {
          "type": "string",
          "description": "Mission identifier from data/index.json."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "complete"
          ]
        }
      },
      "required": [
        "mission",
        "status"
      ],
      "additionalProperties": false
    },
    "description": {
      "type": [
        "string",
        "array"
      ],
      "description": "Body text of the room. Can be a flat string or conditional variant array.",
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "condition": {
            "$ref": "#/definitions/condition"
          }
        },
        "required": [
          "text"
        ],
        "additionalProperties": false
      }
    },
    "autoAttack": {
      "type": "object",
      "properties": {
        "enemies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "condition": {
          "$ref": "#/definitions/condition"
        },
        "onVictory": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/action"
          }
        }
      },
      "required": [
        "enemies"
      ],
      "additionalProperties": false
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "isBack": {
            "type": "boolean",
            "description": "If true, sorts this option to the bottom as a 'back'/exit choice (locale-independent alternative to a 'return' action)."
          },
          "log": {
            "type": [
              "boolean",
              "string"
            ],
            "description": "False silences logging; a string prints a custom narrative description."
          },
          "condition": {
            "$ref": "#/definitions/condition"
          },
          "requirements": {
            "type": "object",
            "properties": {
              "item": {
                "type": "string",
                "description": "Item ID required in inventory to enable choice."
              }
            },
            "required": [
              "item"
            ],
            "additionalProperties": false
          },
          "actions": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/action"
            }
          },
          "timeCost": {
            "type": "integer",
            "minimum": 0,
            "description": "Ticks this option advances the world clock. Overrides rules.time.defaultCosts; 0 opts out explicitly."
          }
        },
        "required": [
          "text"
        ],
        "additionalProperties": false
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "retryText": {
            "description": "Replacement option/log text once the check has been attempted: a string, or an array walked per failed attempt (clamped to the last entry). Attempt counts reset on scene re-entry.",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 1
              }
            ]
          },
          "skillCheck": {
            "type": "string",
            "description": "Attribute ID to roll d20 check against."
          },
          "dc": {
            "type": "integer",
            "minimum": 1
          },
          "condition": {
            "$ref": "#/definitions/condition"
          },
          "actions": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/action"
            },
            "description": "Action pipeline executed on successful checks (shorthand for outcomes.success.actions)."
          },
          "onFailure": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/action"
            },
            "description": "Action pipeline executed on failed checks (shorthand for outcomes.failure.actions)."
          },
          "outcomes": {
            "$ref": "#/definitions/outcomes"
          },
          "resolveOnce": {
            "type": "boolean",
            "description": "Fail-forward: the check rolls exactly once and then retires permanently, whatever the tier. Route the failure/partial tiers somewhere real."
          },
          "maxAttempts": {
            "type": "integer",
            "minimum": 1,
            "description": "Attempt budget. When it runs out without a success the check retires and onExhausted runs."
          },
          "onExhausted": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/action"
            },
            "description": "Pipeline run once when maxAttempts is exhausted — the authored way out (fail-forward alternative route)."
          },
          "resultText": {
            "description": "Narrative checks (no dc, no items): the narration logged on use. A string, or an array walked per use (clamped to the last entry).",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 1
              }
            ]
          },
          "repeatable": {
            "type": "boolean",
            "description": "Narrative checks: keep the option available after use instead of retiring it."
          },
          "timeCost": {
            "type": "integer",
            "minimum": 0,
            "description": "Ticks one attempt advances the world clock. Overrides rules.time.defaultCosts.skillAttempt; 0 opts out explicitly."
          },
          "apCost": {
            "type": "integer",
            "minimum": 0,
            "description": "AP one attempt costs. Overrides rules.apEconomy.skillAttemptCost; 0 opts out explicitly. Narrative (roll-free) checks only charge an explicit apCost."
          },
          "items": {
            "type": "array",
            "description": "Item-discovery entries supporting sequential search yields.",
            "items": {
              "type": "object",
              "properties": {
                "item": {
                  "type": "string"
                },
                "table": {
                  "type": "string",
                  "description": "Loot table ID to draw random drop."
                },
                "amount": {
                  "type": "integer",
                  "minimum": 1
                },
                "itemDrops": {
                  "type": "integer",
                  "minimum": 1
                },
                "dc": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "additionalProperties": false
            }
          }
        },
        "required": [
          "text"
        ],
        "anyOf": [
          {
            "required": [
              "skillCheck"
            ]
          }
        ],
        "additionalProperties": false
      }
    },
    "passiveChecks": {
      "type": "array",
      "description": "Checks auto-rolled silently on the player's first entry, writing pass/fail into an author-named flag that conditions and description variants read. Rolled once per game.",
      "items": {
        "type": "object",
        "properties": {
          "skillCheck": {
            "type": "string",
            "description": "Attribute ID to roll d20 check against."
          },
          "dc": {
            "type": "integer",
            "minimum": 1
          },
          "flag": {
            "type": "string",
            "description": "Flag the pass/fail result is written to."
          },
          "text": {
            "type": "string",
            "description": "Narration logged when the passive check succeeds. Silent otherwise."
          }
        },
        "required": [
          "skillCheck",
          "flag"
        ],
        "additionalProperties": false
      }
    },
    "supportsExhibits": {
      "type": "boolean",
      "description": "If true, this scene supports exhibits curatorship."
    },
    "displays": {
      "type": "array",
      "description": "Initial display cases defined in this scene.",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "item": {
            "type": [
              "string",
              "null"
            ]
          },
          "allowedTypes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "name"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "region"
  ],
  "anyOf": [
    {
      "required": [
        "title"
      ]
    },
    {
      "required": [
        "name"
      ]
    }
  ],
  "additionalProperties": false,
  "definitions": {
    "condition": {
      "type": "object",
      "properties": {
        "and": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/condition"
          }
        },
        "or": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/condition"
          }
        },
        "not": {
          "$ref": "#/definitions/condition"
        },
        "flag": {
          "type": "string"
        },
        "value": {
          "type": "boolean"
        },
        "item": {
          "type": "string"
        },
        "count": {
          "type": "integer",
          "minimum": 1
        },
        "gold": {
          "type": [
            "integer",
            "object"
          ]
        },
        "level": {
          "type": [
            "integer",
            "object"
          ]
        },
        "mission": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "complete",
            "not_started"
          ]
        },
        "time": {
          "type": [
            "integer",
            "object"
          ],
          "description": "Absolute elapsed world-clock ticks."
        },
        "day": {
          "type": [
            "integer",
            "object"
          ],
          "description": "1-based day number (requires rules.time)."
        },
        "segment": {
          "type": "string",
          "description": "Current day segment id (requires rules.time.segments)."
        }
      },
      "additionalProperties": {
        "type": [
          "integer",
          "object"
        ]
      }
    },
    "outcomeTier": {
      "type": "object",
      "properties": {
        "margin": {
          "type": "integer",
          "minimum": 1,
          "description": "critical: beat the DC by at least this much (default 5). partial: miss the DC by at most this much (default 3). Ignored on success/failure."
        },
        "text": {
          "type": "string",
          "description": "Narration logged when this tier lands."
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/action"
          }
        }
      },
      "additionalProperties": false
    },
    "outcomes": {
      "type": "object",
      "description": "Margin-based outcome tiers. critical and partial only exist when authored; success/failure default to the legacy actions/onFailure pipelines. partial is the fail-forward tier: you get the thing, with a catch.",
      "properties": {
        "critical": {
          "$ref": "#/definitions/outcomeTier"
        },
        "success": {
          "$ref": "#/definitions/outcomeTier"
        },
        "partial": {
          "$ref": "#/definitions/outcomeTier"
        },
        "failure": {
          "$ref": "#/definitions/outcomeTier"
        }
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "destination": {
          "type": "string"
        },
        "flag": {
          "type": "string"
        },
        "value": {
          "type": "boolean"
        },
        "item": {
          "type": "string"
        },
        "amount": {
          "type": [
            "integer",
            "string"
          ],
          "description": "loot/heal: integer. modify_ap / modify_resource: integer (negative drains) or \"full\"."
        },
        "resource": {
          "type": "string",
          "description": "modify_resource: id of a resource declared in rules.playerDefaults.resources."
        },
        "xpReward": {
          "type": "integer"
        },
        "enemies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "onVictory": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/action"
          }
        },
        "npc": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "chest": {
          "type": "string"
        },
        "mission": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "complete"
          ]
        },
        "node": {
          "type": "string"
        },
        "tradeDiscount": {
          "type": [
            "number",
            "string"
          ]
        },
        "persistDiscount": {
          "type": "boolean"
        },
        "id": {
          "type": "string",
          "description": "set_timer / cancel_timer: the timer id."
        },
        "afterTicks": {
          "type": "integer",
          "minimum": 0,
          "description": "set_timer: deadline relative to the current tick."
        },
        "atTick": {
          "type": "integer",
          "minimum": 0,
          "description": "set_timer: absolute deadline tick."
        },
        "until": {
          "type": "string",
          "description": "advance_time: advance to the next start of this day segment."
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/action"
          },
          "description": "set_timer: the (quiet-only) pipeline run when the timer fires."
        }
      },
      "required": [
        "type"
      ]
    }
  }
}
