{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gravity Scene Definition",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Visual header name of the scene. Takes precedence over 'name'."
    },
    "name": {
      "type": "string",
      "description": "Display name of the scene (used for map tags and fallback headers)."
    },
    "region": {
      "type": "string",
      "description": "Region key from data/index.json indicating map grouping."
    },
    "xpReward": {
      "type": "integer",
      "minimum": 1,
      "description": "One-time XP bonus awarded to the player upon their first entry."
    },
    "descriptionHook": {
      "type": "string",
      "description": "Optional runtime callback hook (e.g., 'museumChestContents') to append dynamic text."
    },
    "mapDefinitions": {
      "type": "object",
      "properties": {
        "top": { "type": "integer" },
        "left": { "type": "integer" },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "background": {
          "type": "string",
          "description": "CSS color expression used to draw room nodes on the map canvas."
        }
      },
      "required": ["top", "left", "width", "height"],
      "additionalProperties": false
    },
    "questTrigger": {
      "type": "object",
      "properties": {
        "mission": { "type": "string", "description": "Mission identifier from data/index.json." },
        "status": { "type": "string", "enum": ["active", "complete"] }
      },
      "required": ["mission", "status"],
      "additionalProperties": false
    },
    "description": {
      "type": ["string", "array"],
      "description": "Body text of the room. Can be a flat string or conditional variant array.",
      "items": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "condition": { "$ref": "#/definitions/condition" }
        },
        "required": ["text"],
        "additionalProperties": false
      }
    },
    "autoAttack": {
      "type": "object",
      "properties": {
        "enemies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "condition": { "$ref": "#/definitions/condition" },
        "onVictory": {
          "type": "array",
          "items": { "$ref": "#/definitions/action" }
        }
      },
      "required": ["enemies"],
      "additionalProperties": false
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "isBack": {
            "type": "boolean",
            "description": "If true, sorts this option to the bottom as a 'back'/exit choice (locale-independent alternative to a 'return' action)."
          },
          "log": {
            "type": ["boolean", "string"],
            "description": "False silences logging; a string prints a custom narrative description."
          },
          "condition": { "$ref": "#/definitions/condition" },
          "requirements": {
            "type": "object",
            "properties": {
              "item": { "type": "string", "description": "Item ID required in inventory to enable choice." }
            },
            "required": ["item"],
            "additionalProperties": false
          },
          "actions": {
            "type": "array",
            "items": { "$ref": "#/definitions/action" }
          }
        },
        "required": ["text"],
        "additionalProperties": false
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "retryText": {
            "description": "Replacement option/log text once the check has been attempted: a string, or an array walked per failed attempt (clamped to the last entry). Attempt counts reset on scene re-entry, like escalated DCs.",
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" }, "minItems": 1 }
            ]
          },
          "skillCheck": { "type": "string", "description": "Attribute ID to roll d20 check against." },
          "dc": { "type": "integer", "minimum": 1 },
          "increment": { "type": "integer", "description": "Difficulty escalation points added per failure." },
          "condition": { "$ref": "#/definitions/condition" },
          "actions": {
            "type": "array",
            "items": { "$ref": "#/definitions/action" },
            "description": "Action pipeline executed on successful checks."
          },
          "onFailure": {
            "type": "array",
            "items": { "$ref": "#/definitions/action" },
            "description": "Action pipeline executed on failed checks."
          },
          "items": {
            "type": "array",
            "description": "Item-discovery entries supporting sequential search yields.",
            "items": {
              "type": "object",
              "properties": {
                "item": { "type": "string" },
                "table": { "type": "string", "description": "Loot table ID to draw random drop." },
                "amount": { "type": "integer", "minimum": 1 },
                "itemDrops": { "type": "integer", "minimum": 1 },
                "dc": { "type": "integer", "minimum": 1 },
                "increment": { "type": "integer" }
              },
              "additionalProperties": false
            }
          }
        },
        "required": ["text", "skillCheck"],
        "additionalProperties": false
      }
    },
    "supportsExhibits": {
      "type": "boolean",
      "description": "If true, this scene supports exhibits curatorship."
    },
    "displays": {
      "type": "array",
      "description": "Initial display cases defined in this scene.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "item": { "type": ["string", "null"] },
          "allowedTypes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["id", "name"],
        "additionalProperties": false
      }
    }
  },
  "required": ["region"],
  "anyOf": [
    { "required": ["title"] },
    { "required": ["name"] }
  ],
  "additionalProperties": false,

  "definitions": {
    "condition": {
      "type": "object",
      "properties": {
        "and": { "type": "array", "items": { "$ref": "#/definitions/condition" } },
        "or": { "type": "array", "items": { "$ref": "#/definitions/condition" } },
        "not": { "$ref": "#/definitions/condition" },
        "flag": { "type": "string" },
        "value": { "type": "boolean" },
        "item": { "type": "string" },
        "count": { "type": "integer", "minimum": 1 },
        "gold": { "type": ["integer", "object"] },
        "level": { "type": ["integer", "object"] },
        "mission": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "complete", "not_started"] }
      },
      "additionalProperties": {
        "type": ["integer", "object"]
      }
    },
    
    "action": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "destination": { "type": "string" },
        "flag": { "type": "string" },
        "value": { "type": "boolean" },
        "item": { "type": "string" },
        "amount": { "type": "integer" },
        "xpReward": { "type": "integer" },
        "enemies": { "type": "array", "items": { "type": "string" } },
        "onVictory": { "type": "array", "items": { "$ref": "#/definitions/action" } },
        "npc": { "type": "string" },
        "message": { "type": "string" },
        "chest": { "type": "string" },
        "mission": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "complete"] },
        "node": { "type": "string" },
        "tradeDiscount": { "type": ["number", "string"] },
        "persistDiscount": { "type": "boolean" }
      },
      "required": ["type"]
    }
  }
}
